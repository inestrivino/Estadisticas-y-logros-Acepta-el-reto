{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "sourceRoot": "app/back/src",
    "rootDir": "src",
    "outDir": "./dist-server",
    "strict": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "sourceMap": true
  }
}