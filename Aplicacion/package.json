{
  "name": "tfg",
  "type": "module",
  "scripts": {
    "start": "node ./startDev.js",
    "clean-volumes": "docker rm -v app-front-dev app-back-dev",
    "start-local": "docker start redis || docker run --name redis -p 6379:6379 redis:alpine",
    "casos": "node back/scripts/generarProblemas.js",

    "start-prod": "docker compose -f compose.prod.yaml up --build",

    "start-prueba": "docker compose -f compose.prueba.yaml up --build",
    "push": "npm run build:back && npm run build:front && npm run push:back && npm run push:front",
    "build:back": "docker build -t n3stor173/app-back:latest -f ./back/Dockerfile.prod .",
    "build:front": "docker build -t n3stor173/app-front:latest -f ./front/Dockerfile.prod .",
    "push:back": "docker push n3stor173/app-back:latest",
    "push:front": "docker push n3stor173/app-front:latest"
  }
}