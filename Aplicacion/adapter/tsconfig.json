{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "rootDir": "src",
    "outDir": "./dist",
    "strict": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": false
  },
  "exclude": [
    "vitest.config.ts",
     "**/*.test.ts",
     "test/**/*",
  ]
}