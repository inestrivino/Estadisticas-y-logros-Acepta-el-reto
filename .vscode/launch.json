{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "attach",
            "name": "Adjuntar debugger al back",
            "cwd": "${workspaceFolder}/Aplicacion/back",
            "localRoot": "${workspaceFolder}/Aplicacion/back",
            "remoteRoot": "/app/back",
            "port": 9229,
            "restart": true,
        },
        {
            "type": "node",
            "request": "attach",
            "name": "Adjuntar debugger al adapter",
            "cwd": "${workspaceFolder}/Aplicacion/adapter",
            "localRoot": "${workspaceFolder}/Aplicacion/adapter",
            "remoteRoot": "/app/adapter",
            "port": 9230,
            "restart": true,
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug en local",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev-local"
            ],
            "cwd": "${workspaceFolder}/Aplicacion/back",
            "env": {
                "REDIS_URL": "redis://localhost:6379"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Debug Chrome",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/Aplicacion/front"
        }
    ]
}